# FIT·NOTE 環境変数サンプル。
# このファイルを .env.local にコピーして値を埋めてください（.env.local は git 管理外）。

# ── Supabase（フェーズ1の永続化先） ───────────────────────────────
# 未設定でもアプリは起動します（自動で localStorage フォールバックに切替）。
# supabase.com でプロジェクトを作成し、Settings → API から取得。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー側専用（フェーズ3の日次カウント強制などで使用予定。クライアントに出さない）
# SUPABASE_SERVICE_ROLE_KEY=

# フェーズ1で使う固定デモユーザーの UUID（省略時は既定値）
# NEXT_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# ── OpenAI（フェーズ3の食事写真解析。route.ts が参照） ─────────────
# platform.openai.com で発行（新規は $5 無料クレジット）
OPENAI_API_KEY=
# 省略時は gpt-4o。安く回すなら gpt-4.1-mini
# OPENAI_MODEL=gpt-4o
